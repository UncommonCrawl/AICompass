rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function adminEmails() {
      return [
        "your-admin-email@example.com"
      ];
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email in adminEmails();
    }

    match /compass-results-v2/{submissionId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /compass-public-dots-v1/{submissionId} {
      allow read: if true;
      allow create, update: if false;
      allow delete: if resource.data.is_dev == true;
    }

    match /compass-public-dot-archive-v1/{archiveId} {
      allow read: if true;
      allow write: if false;
    }

    match /compass-submission-private-v1/{submissionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /compass-repeat-signals-v1/{signalId} {
      allow read, write: if false;
    }

    match /compass-events-v1/{eventId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly([
          "event_name",
          "created_at",
          "details"
        ])
        && request.resource.data.event_name in [
          "quiz_start",
          "quiz_complete",
          "result_share_click",
          "result_copy_click"
        ]
        && request.resource.data.created_at is timestamp
        && request.resource.data.details is map;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
